# AWS IoT Core
IOT_ENDPOINT=your-endpoint-ats.iot.ap-south-1.amazonaws.com
IOT_CLIENT_ID=sepsiswatch-simulator
IOT_TOPIC=sepsiswatch/vitals

# Certificate paths
CERT_FILE=certs/your-certificate.pem.crt
KEY_FILE=certs/your-private.pem.key
ROOT_CA=certs/AmazonRootCA1.pem

# AWS Region
AWS_REGION=ap-south-1

# SNS Alert Topic ARN
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:YOUR_ACCOUNT_ID:SepsisAlert

# Risk threshold (0-100)
RISK_THRESHOLD=65
